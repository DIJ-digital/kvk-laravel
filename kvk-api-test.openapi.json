{
  "openapi": "3.0.3",
  "info": {
    "title": "KVK Handelsregister API — Test Environment",
    "description": "KVK (Kamer van Koophandel) Handelsregister API test environment. All endpoints use fictitious test data and require no registration.\n\nTest API Key: `l7xx1f2691f2520d487b902f4e0b57a0b197`\n\nSee https://developers.kvk.nl/nl/documentation/testing for full documentation.",
    "version": "2.0.0",
    "contact": {
      "name": "KVK Developer Portal",
      "url": "https://developers.kvk.nl"
    }
  },
  "servers": [
    {
      "url": "https://api.kvk.nl/test",
      "description": "KVK Test Environment"
    }
  ],
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "tags": [
    {
      "name": "Zoeken",
      "description": "Search the KVK registry by name, KVK number, address, etc."
    },
    {
      "name": "Basisprofiel",
      "description": "Company base profile — owner, main branch, branches listing"
    },
    {
      "name": "Vestigingsprofiel",
      "description": "Branch (vestiging) profile details"
    },
    {
      "name": "Naamgeving",
      "description": "Trade names (handelsnamen) for a KVK number"
    }
  ],
  "paths": {
    "/api/v2/zoeken": {
      "get": {
        "tags": ["Zoeken"],
        "operationId": "zoeken",
        "summary": "Search the KVK registry",
        "description": "Search for companies and branches by name, KVK number, RSIN, branch number, address, or type.\n\nTest KVK numbers:\n- 69599084 (Eenmanszaak)\n- 68727720 (NV)\n- 90004760 (NV)\n- 68750110 (BV)\n- 90001354 (BV)\n- 69599068 (Stichting)\n- 90000102 (Stichting)\n- 90006623 (Stichting)\n- 69599076 (VoF)\n- 90005414 (VoF)\n- 55344526 (Coöperatie)\n- 90002520 (Kerkgenootschap)\n- 90002490 (Onderlinge Waarborg Maatschappij)\n- 90001745 (Maatschap)\n- 90003942 (Commanditaire Vennootschap)\n- 55505201 (Overige Privaatrechtelijke Rechtspersoon)\n- 90000749 (Vereniging van Eigenaars)\n- 90004973 (Error response test case)\n- 90002903 (Error message test case)",
        "parameters": [
          {
            "name": "kvkNummer",
            "in": "query",
            "description": "KVK number (8 digits)",
            "schema": { "type": "string", "example": "69599084" }
          },
          {
            "name": "rsin",
            "in": "query",
            "description": "RSIN number (9 digits)",
            "schema": { "type": "string" }
          },
          {
            "name": "vestigingsnummer",
            "in": "query",
            "description": "Branch number (12 digits)",
            "schema": { "type": "string", "example": "000037178598" }
          },
          {
            "name": "naam",
            "in": "query",
            "description": "Trade name or statutory name (exact word matching, not prefix)",
            "schema": { "type": "string", "example": "test" }
          },
          {
            "name": "straatnaam",
            "in": "query",
            "description": "Street name",
            "schema": { "type": "string", "example": "Rietdekkershof" }
          },
          {
            "name": "huisnummer",
            "in": "query",
            "description": "House number (only with postcode)",
            "schema": { "type": "integer" }
          },
          {
            "name": "huisletter",
            "in": "query",
            "description": "House letter (only with huisnummer, single letter)",
            "schema": { "type": "string" }
          },
          {
            "name": "postcode",
            "in": "query",
            "description": "Postal code (only with huisnummer or postbusnummer)",
            "schema": { "type": "string" }
          },
          {
            "name": "postbusnummer",
            "in": "query",
            "description": "PO Box number (only with postcode)",
            "schema": { "type": "integer" }
          },
          {
            "name": "plaats",
            "in": "query",
            "description": "City name",
            "schema": { "type": "string", "example": "Veendam" }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Filter by type. Combine with multiple &type= params.",
            "schema": {
              "type": "string",
              "enum": ["hoofdvestiging", "nevenvestiging", "rechtspersoon"]
            },
            "example": "hoofdvestiging"
          },
          {
            "name": "inclusiefInactieveRegistraties",
            "in": "query",
            "description": "Include inactive registrations (default: false)",
            "schema": { "type": "boolean", "default": false }
          },
          {
            "name": "pagina",
            "in": "query",
            "description": "Page number (1–1000)",
            "schema": { "type": "integer", "minimum": 1, "maximum": 1000, "default": 1 }
          },
          {
            "name": "resultatenPerPagina",
            "in": "query",
            "description": "Results per page (default: 10, max: 100)",
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 10 }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ZoekenResponse" },
                "example": {
                  "pagina": 1,
                  "resultatenPerPagina": 10,
                  "totaal": 1,
                  "resultaten": [
                    {
                      "kvkNummer": "69599068",
                      "vestigingsnummer": "000037178598",
                      "naam": "Test Stichting Bolderbast",
                      "adres": {
                        "binnenlandsAdres": {
                          "type": "bezoekadres",
                          "straatnaam": "Hizzaarderlaan",
                          "huisnummer": 1,
                          "postcode": "1234AB",
                          "plaats": "Lollum"
                        }
                      },
                      "type": "hoofdvestiging",
                      "actief": "Ja",
                      "links": [
                        {
                          "rel": "basisprofiel",
                          "href": "https://api.kvk.nl/api/v1/basisprofielen/69599068"
                        },
                        {
                          "rel": "vestigingsprofiel",
                          "href": "https://api.kvk.nl/api/v1/vestigingsprofielen/000037178598"
                        }
                      ]
                    }
                  ],
                  "links": [
                    {
                      "rel": "self",
                      "href": "https://api.kvk.nl/test/api/v2/zoeken?naam=test&pagina=1&resultatenperpagina=10"
                    }
                  ]
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/ServerError" }
        }
      }
    },
