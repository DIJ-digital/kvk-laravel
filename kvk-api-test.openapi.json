              "bv": { "value": "68750110", "summary": "BV" },
              "bv2": { "value": "90001354", "summary": "BV (2)" },
              "nv": { "value": "68727720", "summary": "NV" },
              "nv2": { "value": "90004760", "summary": "NV (2)" },
              "stichting": { "value": "69599068", "summary": "Stichting" },
              "stichting2": { "value": "90000102", "summary": "Stichting (2)" },
              "stichting3": { "value": "90006623", "summary": "Stichting (3)" },
              "vof": { "value": "69599076", "summary": "VoF" },
              "vof2": { "value": "90005414", "summary": "VoF (2)" },
              "cooperatie": { "value": "55344526", "summary": "Coöperatie" },
              "kerkgenootschap": { "value": "90002520", "summary": "Kerkgenootschap" },
              "onderlinge": { "value": "90002490", "summary": "Onderlinge Waarborg Maatschappij" },
              "maatschap": { "value": "90001745", "summary": "Maatschap" },
              "cv": { "value": "90003942", "summary": "Commanditaire Vennootschap" },
              "overige": { "value": "55505201", "summary": "Overige Privaatrechtelijke Rechtspersoon" },
              "vve": { "value": "90000749", "summary": "Vereniging van Eigenaars" },
