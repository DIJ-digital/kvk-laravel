              "fout": {
                "code": "IPD1999",
                "omschrijving": "Opgegeven parameter(s) ongeldig"
              }
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Not authenticated — missing or invalid API key (401)",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "fout": {
                "code": "401",
                "omschrijving": "Not authenticated"
              }
            }
          }
        }
      },
      "NotFound": {
        "description": "Not found — no results or invalid resource (404)",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "fout": {
                "code": "IPD5200",
                "omschrijving": "Geen resultaten gevonden voor de opgegeven zoekparameters"
              }
            }
          }
        }
      },
      "ServerError": {
        "description": "Internal server error (500)",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "fout": {
                "code": "IPD9999",
                "omschrijving": "Algemene technische fout"
              }
            }
          }
        }
      }
    },
    "schemas": {
